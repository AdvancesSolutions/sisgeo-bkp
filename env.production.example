# Copie para .env.production e preencha os valores
# NUNCA commite .env.production no Git

# === Banco de Dados (RDS) ===
DB_HOST=seu-rds-endpoint.sa-east-1.rds.amazonaws.com
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=sigeo

# === AWS (para S3 e ECS) ===
AWS_REGION=sa-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=sistema-limpeza-evidencias

# Em ECS: use IAM Task Role (não precisa de Access Key)

# === JWT ===
JWT_SECRET=
JWT_REFRESH_SECRET=

# === API ===
NODE_ENV=production
PORT=3000
CORS_ORIGIN=https://sigeo.advances.com.br,https://main.da1hucc7ed5a9.amplifyapp.com
