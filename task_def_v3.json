            "image": "320674390105.dkr.ecr.sa-east-1.amazonaws.com/sigeo-api:latest",
            "cpu": 0,
            "portMappings": [
                {
                    "containerPort": 3000,
                    "hostPort": 3000,
                    "protocol": "tcp"
