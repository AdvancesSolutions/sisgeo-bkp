            ],
            "essential": true,
            "environment": [
                {
                    "name": "JWT_REFRESH_SECRET",
                    "value": "657c436814463e82fba56e0767166c75420ee3c8ee070f80f514fa7fb3fa07e5"
                },
                {
                    "name": "PORT",
                    "value": "3000"
                },
                {
                    "name": "DB_PORT",
                    "value": "5432"
                },
                {
                    "name": "JWT_SECRET",
                    "value": "a6fccbc898f47e21d2723efc2b776ad0785486b7a0d746cc6c086f640f2ede"
                },
                {
                    "name": "DB_USER",
                    "value": "postgres"
                },
                {
                    "name": "NODE_ENV",
                    "value": "production"
                },
                {
                    "name": "DB_NAME",
                    "value": "sigeo"
                },
                {
                    "name": "DB_HOST",
                    "value": "sigeo-db.c7qe4cecc3pa.sa-east-1.rds.amazonaws.com"
                },
                {
                    "name": "DB_PASSWORD",
                    "value": "sigeo1234"
                },
                {
                    "name": "DEBUG",
