# =============================================================================
# SIGEO API - Variáveis de Produção (AWS)
# Copie para .env.production e preencha. NUNCA commite .env.production no Git.
# =============================================================================

NODE_ENV=production
PORT=3000

# === Banco de Dados (RDS PostgreSQL) ===
DB_HOST=seu-rds-endpoint.sa-east-1.rds.amazonaws.com
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=sigeo

# === Redis (ElastiCache ou instância) ===
REDIS_URL=redis://seu-elasticache-endpoint:6379

# === JWT ===
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# === AWS (S3, CloudFront) ===
AWS_REGION=sa-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=sistema-limpeza-evidencias
CLOUDFRONT_URL=https://seu-distribuicao.cloudfront.net

# Em ECS: use IAM Task Role (não precisa de Access Key)

# === Ollama (Vision AI / Voice) ===
OLLAMA_URL=http://ollama:11434

# === CORS ===
CORS_ORIGIN=https://sigeo.advances.com.br,https://main.da1hucc7ed5a9.amplifyapp.com

# === App URL (links em e-mails) ===
APP_URL=https://sigeo.advances.com.br

# === SLA Alertas (SMTP) ===
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@sigeo.advances.com.br
SLA_ALERT_EMAIL=

# === Relatórios PDF ===
LOGO_PATH=/app/public/logo.png
