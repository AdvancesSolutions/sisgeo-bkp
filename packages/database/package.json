    "bcrypt": "^5.1.1"
  },
  "devDependencies": {
    "prisma": "^6.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  },
  "prisma": {
    "schema": "prisma/schema.prisma",
    "seed": "ts-node src/seed.ts"
  }
